{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build:site",
      "label": "build:site",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "build:debug",
      "label": "build:debug",
      "problemMatcher": []
    },
    {
      "label": "serve",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "http.server",
        "8000"
      ],
      "isBackground": true,
      "dependsOn": [
        "build:debug"
      ],
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}/build"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP on"
        }
      }
    }
  ]
}
