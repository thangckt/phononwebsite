{
  "name": "phononwebsite",
  "version": "0.2.0",
  "description": "Javascript web app to visualise lattice vibrations",
  "main": "build/main.js",
  "directories": {
    "doc": "doc",
    "test": "test"
  },
  "dependencies": {
    "complex": "3.0.1",
    "gif.js": "0.2.0",
    "highcharts": "12.2.0",
    "jquery": "3.7.1",
    "js-yaml": "4.1.0",
    "three": "0.124.0",
    "whammy": "0.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "chai": "^5.2.0",
    "esbuild-register": "^3.6.0",
    "jsdom": "^24.1.3",
    "mocha": "^11.5.0",
    "rollup": "^2.79.0",
    "terser": "^5.44.0"
  },
  "scripts": {
    "clean:build": "rm -rf build && mkdir -p build",
    "build": "npm run clean:build && rollup -c",
    "build-uglify": "npm run build && terser build/main.js -c -m --source-map \"content=build/main.js.map,url=main.min.js.map\" -o build/main.min.js && terser build/exciton.js -c -m --source-map \"content=build/exciton.js.map,url=exciton.min.js.map\" -o build/exciton.min.js",
    "copy": "mkdir -p build/test && cp -r figures css libs data README.md index.html phonon.html exciton.html favicon.svg favicon.ico build/ && cp -r test/fixtures build/test/",
    "check:build-artifacts": "test -f build/main.min.js && test -f build/exciton.min.js",
    "build:site": "npm run build-uglify && npm run copy && npm run check:build-artifacts",
    "test": "npm run build-uglify && mocha \"test/**/*.test.cjs\"",
    "test:browser": "PLAYWRIGHT_SMOKE=1 mocha test/browser-smoke.test.cjs --timeout 30000",
    "test:py": "python3 -m pytest python/phononweb/tests -q"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquemiranda/phononwebsite.git"
  },
  "keywords": [
    "phonons",
    "visualization",
    "lattice",
    "vibrations",
    "webgl",
    "javascript",
    "threejs",
    "javascript"
  ],
  "author": "Henrique Miranda",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/henriquemiranda/phononwebsite/issues"
  },
  "homepage": "https://github.com/henriquemiranda/phononwebsite#readme"
  ,
  "overrides": {
    "serialize-javascript": "7.0.5"
  }
}
