{
  "name": "phononwebsite",
  "version": "0.2.0",
  "description": "Javascript web app to visualise lattice vibrations",
  "main": "build/main.js",
  "directories": {
    "doc": "doc",
    "test": "test"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "assert": "^1.4.1",
    "ccapture.js": "^1.1.0",
    "ccapture.js-npmfixed": "^1.1.0",
    "complex": "^3.0.1",
    "gif.js": "^0.2.0",
    "highcharts": "^12.2.0",
    "jquery": "^3.7.1",
    "js-yaml": "^4.1.0",
    "three": "^0.124.0",
    "whammy": "^0.0.1"
  },
  "devDependencies": {
    "chai": "^5.2.0",
    "esbuild-register": "^3.6.0",
    "jsdom": "^24.1.3",
    "mocha": "^11.5.0",
    "rollup": "^2.79.0",
    "terser": "^5.44.0"
  },
  "scripts": {
    "clean:build": "rm -rf build && mkdir -p build",
    "build": "npm run clean:build && rollup -c",
    "build-uglify": "npm run build && terser build/main.js -c -m --source-map \"content=build/main.js.map,url=main.min.js.map\" -o build/main.min.js",
    "copy": "mkdir -p build/test && cp -r figures css libs contribdb localdb mpdb README.md index.html phonon.html build/ && cp -r test/fixtures build/test/",
    "test": "npm run build-uglify && mocha test/smoke.test.cjs test/legacy-migrated.test.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquemiranda/phononwebsite.git"
  },
  "keywords": [
    "phonons",
    "visualization",
    "lattice",
    "vibrations",
    "webgl",
    "javascript",
    "threejs",
    "javascript"
  ],
  "author": "Henrique Miranda",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/henriquemiranda/phononwebsite/issues"
  },
  "homepage": "https://github.com/henriquemiranda/phononwebsite#readme"
}
